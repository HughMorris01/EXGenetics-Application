<%- include('partials/head') %> 
<%- include('partials/header') %>

<main class="content-wrapper">
  <section class="error-page-section">
    <div class="container">
      <div class="error-card fade-in-card">
        
        <div class="error-icon">
          <i class="fa-solid fa-cloud-bolt"></i>
        </div>
        
        <h1 class="error-title">404</h1>
        <h2 class="error-subtitle">Lost in the Clouds</h2>
        
        <p class="error-text">
          It looks like the page you're looking for isn't in our current rotation. 
          Don't worry—even the best cultivators lose their way in the fog sometimes. Let's get you back on the right path.
        </p>
        
        <div class="error-actions" style="display: flex; gap: 20px; justify-content: center; margin-top: 2rem;">
          <a href="/" class="btn-verify" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">Back to Home</a>
          <a href="/contact" class="btn-exit" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">Contact Us</a>
        </div>

      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>