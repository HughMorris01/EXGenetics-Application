<%- include('partials/head') %> <%- include('partials/header') %>

<main>
  
  <section class="hero-section index-hero">
    <div class="container">
      <h1 class="hero-title-index hero-title-glow">Excelsior Genetics</h1>
      <p class="hero-subtitle">Visionary Cannabis Cultivation</p>

      <hr class="neon-divider" />

      <p class="hero-lead">
        <strong>Excelsior Genetics</strong> is a premier craft genetics
        collective specializing in elite cultivation and the science of the
        cannabis plant. Founded on the mission of bringing world-class quality
        and transparency to the St Lawrence and 1000 Islands' communities.
      </p>

      <hr class="neon-divider" />

      <p class="hero-lead">
        Our retail arm, <strong>Northern Legacy</strong>, is set to become the
        1000 Islands' first dedicated cannabis dispensary. Located squarely
        between <strong>Clayton</strong> and <strong>Alexandria Bay</strong>, directly across
        from the <strong>1000 Islands Bait Store</strong> and just a stones
        throw away from <strong>I-81</strong> and <strong>Wellesley Island</strong>.
      </p>

      <hr class="neon-divider" />

      <div class="hero-callout-row">
        <p class="hero-outrage">
          While we have the full support of our local community, we're currently
          facing a licensing standstill due to administrative delays by the state. Our
          application remains unprocessed despite our ample readiness to serve our
          neighbors.
        </p>

        <div class="action-container">
          <p class="cta-text">
            Stand with us. Help us open the 1000 Islands' first dispensary.
          </p>
          <a href="https://c.org/HrGp2jzv8B" target="_blank" class="btn-petition">Sign Our Petition</a>
        </div>
      </div>

      
    </div>
  </section>

  <section class="features-grid">
    
    <a href="/cultivation" class="feature-card">
      <i class="fa-solid fa-flask-vial feature-icon"></i>
      <h3>Our Process</h3>
      <p>
        From specialized pheno-hunting to rigorous stress-testing, learn how 20 
        years of expertise goes into every plant we cultivate.
      </p>
      <span class="card-link">Learn More &rarr;</span>
    </a>

    <a href="/strains" class="feature-card">
      <i class="fa-solid fa-dna feature-icon"></i>
      <h3>Our Product</h3>
      <p>
        Explore our private genetic vault of rare, elite cultivars curated for maximum expression and world-class quality.
      </p>
      <span class="card-link">View Genetics &rarr;</span>
    </a>

    <a href="/retail" class="feature-card">
      <i class="fa-solid fa-store feature-icon"></i>
      <h3>Our Store</h3>
      <p>
        Visit <strong>Northern Legacy</strong> in Clayton, NY—the 1000 Islands' first premier dedicated craft cannabis destination.
      </p>
      <span class="card-link">Visit Us &rarr;</span>
    </a>

  </section>

  <section class="genetics-section">
      <div class="content-wrapper">
        <h2 class="genetics-header">
          <a href="/strains" class="hero-subtitle header-glow">Featured Genetics</a>
        </h2>

        <p class="hero-lead">
          We've partnered with the <strong>original architects of modern cannabis</strong> to develop a private genetic vault typically unavailable to the commercial market.
          Our process is one of relentless selection. Every cultivar in our lineup has been rigorously stress-tested and <strong>pheno-hunted for maximum expression</strong>.
        </p>

      </div>
  </section>

  <%- include('partials/infinite-carousel') %>

  <section class="petition-wrapper">
  <div class="narrow-container">
    <div class="petition-intro">
      <h2 class="petition-header header-glow">We Need Your Help</h2>
      <p class="hero-lead">
        Our plants are thriving. The science is ready. 
        <strong>Help us open the 1000 Islands' first cannabis dispensary.</strong>
      </p>
    </div>

    <div class="petition-card-monolith">
      <div class="card-header">
        <h3>Community Action Gauge</h3>
      </div>
      
      <div class="card-body">
        <div class="stats-row">
          <p class="target-text">Goal: <strong>500 Signatures</strong></p>
          
          <% if (typeof sigCount !== 'undefined' && sigCount >= 20) { %>
            <p class="current-count" id="signature-text">Current: <strong><%= sigCount %></strong></p>
          <% } else { %>
            <p class="current-count" id="signature-text" style="display: none;">Current: <strong><%= typeof sigCount !== 'undefined' ? sigCount : 0 %></strong></p>
          <% } %>
        </div>

        <div class="progress-bar">
          <div class="progress-fill" id="signature-progress" 
                style="width: <%= typeof sigCount !== 'undefined' ? Math.min((sigCount / 500) * 100, 100) + '%' : '0%' %>">
          </div>
        </div>
        
        <p class="sub-text">We are ready to serve. Tell the State to let us open.</p>
        
        <a href="https://c.org/HrGp2jzv8B" target="_blank" class="btn-petition btn-large">
          Sign The Petition <i class="fa-solid fa-pen-nib"></i>
        </a>
      </div>
    </div>
  </div>
  </section>

</main>

<%- include('partials/footer') %>